---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout
  title="Contacto | Demain Informática"
  lang="es"
  customDescription="Contacta con Demain Informática en Donostia: teléfono 943 320 705, email demain@demaininformatica.com y dirección en Camino Marrutxipi Behea 15."
>
  <section class="py-14 lg:py-24">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Contacto
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
        Hablemos de tu equipo, tu comercio o tu empresa.
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        Para consultas, citas o incidencias, contacta por teléfono o email y te
        indicaremos la mejor forma de ayudarte.
      </p>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      <a
        href="tel:+34943320705"
        class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 transition hover:border-orange-400 dark:border-neutral-700 dark:bg-neutral-900"
      >
        <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
          Teléfono
        </h2>
        <p class="mt-3 text-2xl font-bold text-orange-600">943 320 705</p>
      </a>
      <a
        href="mailto:demain@demaininformatica.com"
        class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 transition hover:border-orange-400 dark:border-neutral-700 dark:bg-neutral-900"
      >
        <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
          Email
        </h2>
        <p class="mt-3 break-words text-lg font-bold text-orange-600">
          demain@demaininformatica.com
        </p>
      </a>
      <div class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100">
          Dirección
        </h2>
        <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
          Camino Marrutxipi Behea 15<br />
          20013 San Sebastián
        </p>
      </div>
    </div>
  </section>
</MainLayout>
