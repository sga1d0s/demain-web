---
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
---

<MainLayout
  title="Asistencia técnica | Demain Informática"
  lang="es"
  customDescription="Asistencia técnica informática en Donostia: soporte remoto, atención a domicilio y diagnóstico de averías."
>
  <section class="py-14 lg:py-24">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Asistencia técnica
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
        Cuéntanos la incidencia y buscamos la forma más rápida de resolverla.
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        Si necesitas ayuda con tu equipo informático, podemos revisar la avería,
        darte un primer diagnóstico y, si hace falta, retirar el equipo para un
        chequeo más exhaustivo y presupuesto.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-800">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Teléfono
        </h2>
        <p class="mt-3 text-2xl font-bold text-orange-600">943 320 705</p>
      </article>
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-800">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Email
        </h2>
        <p class="mt-3 break-words text-lg font-bold text-orange-600">
          demain@demaininformatica.com
        </p>
      </article>
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-800">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Remoto
        </h2>
        <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
          Cuando la incidencia lo permite, nos conectamos al equipo para
          solucionarla sin desplazamiento.
        </p>
      </article>
    </div>

    <div class="mt-10">
      <PrimaryCTA title="Contactar" url="/contacto" />
    </div>
  </section>
</MainLayout>
