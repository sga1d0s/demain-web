---
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
---

<MainLayout
  title="Desarrollo de Software | Demain Informática"
  lang="es"
  customDescription="Desarrollo de software a medida, automatización y soluciones digitales para empresas y comercios."
>
  <section class="py-14 lg:py-24">
    <div class="max-w-3xl">
      <p class="text-sm font-bold tracking-wide text-orange-600 uppercase">
        Desarrollo de Software
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100"
      >
        Soluciones digitales a medida para mejorar procesos y ahorrar tiempo.
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        Desarrollamos todo tipo de aplicaciones, automatizaciones e integraciones adaptadas a
        las necesidades reales de cada negocio.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article
        class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-800"
      >
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Teléfono
        </h2>
        <p class="mt-3 text-2xl font-bold text-orange-600">943 320 705</p>
      </article>
      <article
        class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-800"
      >
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Email
        </h2>
        <p class="mt-3 text-lg font-bold break-words text-orange-600">
          demain@demaininformatica.com
        </p>
      </article>
    </div>

    <div class="mt-10">
      <PrimaryCTA title="Contactar" url="/contacto" />
    </div>
  </section>
</MainLayout>
