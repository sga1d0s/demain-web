---
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
---

<MainLayout
  title="Mantenimiento informático | Demain Informática"
  lang="es"
  customDescription="Planes de mantenimiento informático para pequeños comercios, pymes y clientes con necesidades avanzadas en Donostia."
>
  <section class="py-14 lg:py-24">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Mantenimiento
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
        Mantenimiento informático adaptado a cada cliente.
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        Disponemos de servicios de mantenimiento para pequeños comercios, pymes
        y clientes con necesidades mayores. Estudiamos el entorno, el volumen de
        equipos y la criticidad del trabajo para proponer un plan adecuado.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Básico
        </h2>
        <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
          Soporte y revisiones para comercios o pequeñas oficinas que necesitan
          ayuda puntual y continuidad.
        </p>
      </article>
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Empresa
        </h2>
        <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
          Mantenimiento de equipos, redes, servidores, periféricos y soporte a
          usuarios con o sin contrato.
        </p>
      </article>
      <article class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
          Cloud y seguridad
        </h2>
        <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
          Copias de seguridad, supervisión, actualizaciones y prevención frente
          a malware o ransomware.
        </p>
      </article>
    </div>

    <div class="mt-10">
      <PrimaryCTA title="Consultar tarifas" url="/docs/mantenimiento-bolsa-horas.pdf" />
    </div>
  </section>
</MainLayout>
