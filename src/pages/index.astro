---
import { Image } from 'astro:assets';
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import heroImage from '@images/person-working.avif';
import dashboardImage from '@images/dashboard-image.avif';

const services = [
  {
    title: 'Servicio técnico',
    text: 'Revisión, diagnóstico y reparación de equipos en domicilio, taller o remoto.',
    href: '/servicios',
  },
  {
    title: 'Mantenimiento informático',
    text: 'Planes adaptados para pequeños comercios, pymes y clientes con mayor volumen de equipos.',
    href: '/mantenimiento',
  },
  {
    title: 'Asistencia remota',
    text: 'Resolución ágil de incidencias conectándonos de forma segura al equipo del cliente.',
    href: '/asistencia-tecnica',
  },
];
---

<MainLayout
  title="Demain Informática | Servicio técnico y mantenimiento informático en Donostia"
  lang="es"
  customDescription="Servicio técnico, mantenimiento informático, asistencia remota y asesoramiento tecnológico para particulares, comercios y pymes en Donostia."
>
  <section class="grid gap-10 py-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20">
    <div>
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Servicio informático en Donostia desde 2003
      </p>
      <h1
        class="mt-4 max-w-4xl text-4xl font-bold tracking-tight text-neutral-900 sm:text-5xl lg:text-6xl dark:text-neutral-100"
      >
        Soporte técnico y mantenimiento informático para tu día a día.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700 dark:text-neutral-300">
        Ayudamos a particulares, comercios y pymes con reparación de equipos,
        asistencia remota, mantenimiento, asesoramiento y soluciones adaptadas a
        cada necesidad.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <PrimaryCTA title="Llamar ahora" url="tel:+34943320705" noArrow />
        <SecondaryCTA title="Ver servicios" url="/servicios" />
      </div>
      <div class="mt-8 grid gap-4 text-sm text-neutral-700 sm:grid-cols-3 dark:text-neutral-300">
        <div>
          <strong class="block text-2xl text-neutral-900 dark:text-neutral-100">Desde 2003</strong>
          Servicio cercano y estable
        </div>
        <div>
          <strong class="block text-2xl text-neutral-900 dark:text-neutral-100">943 320 705</strong>
          Atención telefónica
        </div>
        <div>
          <strong class="block text-2xl text-neutral-900 dark:text-neutral-100">Online</strong>
          Soporte remoto
        </div>
      </div>
    </div>
    <div class="overflow-hidden rounded-lg">
      <Image
        src={heroImage}
        alt="Persona trabajando con un ordenador"
        class="h-full min-h-[360px] w-full object-cover"
        loading="eager"
      />
    </div>
  </section>

  <section class="py-10 lg:py-16">
    <div class="mb-8 max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Qué hacemos
      </p>
      <h2 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Servicios informáticos para resolver, prevenir y mejorar.
      </h2>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        services.map(service => (
          <a
            href={service.href}
            class="rounded-lg border border-neutral-300 bg-neutral-100 p-6 transition hover:border-orange-400 hover:bg-white dark:border-neutral-700 dark:bg-neutral-800 dark:hover:border-orange-500"
          >
            <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
              {service.title}
            </h3>
            <p class="mt-3 leading-7 text-neutral-700 dark:text-neutral-300">
              {service.text}
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="grid gap-8 py-10 lg:grid-cols-2 lg:items-center lg:py-16">
    <div class="overflow-hidden rounded-lg">
      <Image
        src={dashboardImage}
        alt="Panel de control y herramientas digitales"
        class="h-full min-h-[320px] w-full object-cover"
      />
    </div>
    <div>
      <p class="text-sm font-bold uppercase tracking-wide text-orange-600">
        Para empresas y comercios
      </p>
      <h2 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Mantenimiento a medida, sin complicar el soporte diario.
      </h2>
      <p class="mt-4 leading-8 text-neutral-700 dark:text-neutral-300">
        Trabajamos con mantenimientos básicos para pequeños comercios y pymes,
        y con planes más completos para clientes que necesitan supervisión,
        copias de seguridad, seguridad y atención continuada.
      </p>
      <div class="mt-6">
        <PrimaryCTA title="Consultar mantenimiento" url="/mantenimiento" />
      </div>
    </div>
  </section>
</MainLayout>
