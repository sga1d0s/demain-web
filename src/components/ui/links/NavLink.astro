---
// Destructure the properties from Astro.props
const { url, name } = Astro.props;

// Define TypeScript interface for the properties
interface Props {
  url: string;
  name: string;
}

const normalizePath = (path: string) => {
  if (path === '/') return '/';
  return path.replace(/\/+$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
const linkPath = normalizePath(url);
const isActive = currentPath === linkPath;

const baseClasses =
  'rounded-lg text-base font-medium ring-zinc-500 outline-hidden focus-visible:ring-3 md:py-2 2xl:text-base dark:ring-zinc-200 dark:focus:outline-hidden';
const inactiveClasses =
  'text-neutral-600 hover:text-neutral-500 dark:text-neutral-400 dark:hover:text-neutral-500';
const activeClasses = 'text-orange-400 dark:text-orange-300';
---

<a
  href={url}
  data-astro-prefetch
  class={`${baseClasses} ${isActive ? activeClasses : inactiveClasses}`}
  aria-current={isActive ? 'page' : undefined}
>
  {name}
</a>
